{
  "name": "@shayarnett/droplet",
  "version": "0.1.4",
  "description": "Smallest Liquid template engine for JavaScript",
  "main": "droplet.js",
  "types": "droplet.d.ts",
  "exports": {
    ".": {
      "types": "./droplet.d.ts",
      "default": "./droplet.js"
    },
    "./ext/liquid-compat": {
      "types": "./ext/liquid-compat.d.ts",
      "default": "./ext/liquid-compat.js"
    },
    "./ext/partials": "./ext/partials.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shayarnett/droplet.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "droplet.js",
    "droplet.min.js",
    "droplet.d.ts",
    "ext/",
    "ext/liquid-compat.d.ts"
  ],
  "scripts": {
    "build": "bun build src/index.js --outfile=droplet.js --format=cjs --target=node --no-splitting && terser droplet.js -o droplet.min.js -c passes=3,toplevel,unsafe,pure_getters -m toplevel",
    "size": "bun -e \"const f=require('fs'),z=require('zlib');const s=f.readFileSync('droplet.min.js');console.log('min:',s.length,'gzip:',z.gzipSync(s).length,'brotli:',z.brotliCompressSync(s).length)\"",
    "test": "bun test.js"
  },
  "devDependencies": {
    "js-yaml": "^4.1.1",
    "liquidjs": "^10.25.0",
    "terser": "^5"
  }
}
